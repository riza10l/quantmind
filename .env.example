# ============================================================
# QuantMind Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ---- Database ----
# For local dev, leave as sqlite (default)
# For production, use PostgreSQL/TimescaleDB
DATABASE_URL=sqlite:///data/quantmind.db
# DATABASE_URL=postgresql://user:password@localhost:5432/quantmind

# ---- Redis (optional, for real-time caching) ----
REDIS_URL=redis://localhost:6379/0

# ---- MLflow ----
MLFLOW_TRACKING_URI=./mlruns
# MLFLOW_TRACKING_URI=http://localhost:5000

# ---- Data Providers ----
# Binance (public endpoints don't require keys for market data)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Binance Testnet (for paper trading)
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# Polygon.io (optional - equities data)
POLYGON_API_KEY=

# CryptoCompare (optional - social/on-chain data)
CRYPTOCOMPARE_API_KEY=

# ---- Execution ----
# Exchange for live trading (binance, bybit, okx)
TRADING_EXCHANGE=binance
TRADING_MODE=paper  # paper | live

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FORMAT=json  # json | console
